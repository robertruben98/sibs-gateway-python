# Copy to .env and fill in. The core library does NOT read .env -- only the
# examples do (via python-dotenv). Never commit real credentials.
SIBS_API_KEY=your_api_key_here
SIBS_TERMINAL_ID=your_terminal_id_here
SIBS_ENVIRONMENT=sandbox
SIBS_WEBHOOK_SECRET=your_webhook_secret_here
# Optional: some SIBS API gateways require a client id header.
SIBS_CLIENT_ID=your_client_id_here
